# ===========================================
# School Financial Management System
# Copy to .env for local dev, or set in Render dashboard
# ===========================================

# Django
SECRET_KEY=generate-a-long-random-secret-key
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=your-app.onrender.com,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://yourdomain.com

# DigitalOcean managed MySQL
DB_NAME=school_fms
DB_USER=your_do_db_user
DB_PASSWORD=your_do_db_password
DB_HOST=db-mysql-xxxxx.db.ondigitalocean.com
DB_PORT=25060
DB_SSL=True
# Optional: path to DO ca-certificate.crt if required
# DB_SSL_CA=/etc/secrets/ca-certificate.crt

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS (comma-separated HTTPS origins)
CORS_ALLOWED_ORIGINS=https://your-app.onrender.com,https://yourdomain.com

# Optional
BACKUP_DIR=/tmp/backups
